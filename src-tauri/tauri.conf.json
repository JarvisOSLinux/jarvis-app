{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "jarvis-ui",
  "version": "0.1.0",
  "identifier": "io.jarvisos.jarvis-ui",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "JARVIS",
        "width": 500,
        "height": 760,
        "minWidth": 400,
        "minHeight": 540,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/*", "resources/widgets/**/*"]
  }
}
